@model ProfileViewModel
@{ ViewData["Title"] = "My Profile"; }

<h2><i class="bi bi-person-circle me-2"></i>My Profile</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Username</dt>
                    <dd class="col-sm-8">@Model.Username</dd>
                    
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@(Model.FirstName ?? "") @(Model.LastName ?? "")</dd>
                    
                    <dt class="col-sm-4">Member Since</dt>
                    <dd class="col-sm-8">@Model.CreatedDate.ToString("MMMM dd, yyyy")</dd>
                    
                    <dt class="col-sm-4">Last Login</dt>
                    <dd class="col-sm-8">@(Model.LastLoginDate?.ToString("MMMM dd, yyyy HH:mm") ?? "N/A")</dd>
                    
                    <dt class="col-sm-4">Saved Comics</dt>
                    <dd class="col-sm-8">@Model.SavedComicsCount</dd>
                    
                    <dt class="col-sm-4">Role</dt>
                    <dd class="col-sm-8">
                        @foreach (var role in Model.Roles)
                        {
                            <span class="badge bg-primary me-1">@role</span>
                        }
                    </dd>
                </dl>
                
                <hr>
                <a asp-action="ChangePassword" class="btn btn-outline-primary">
                    <i class="bi bi-key me-2"></i>Change Password
                </a>
            </div>
        </div>
    </div>
</div>
