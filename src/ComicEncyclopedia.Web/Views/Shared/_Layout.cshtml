<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fantasy B'zaar Encyclopedia</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <style>
        :root { --fbz-primary: #6f42c1; --fbz-secondary: #e83e8c; --fbz-dark: #2d1b4e; }
        body { min-height: 100vh; display: flex; flex-direction: column; }
        .navbar { background: linear-gradient(135deg, var(--fbz-dark) 0%, var(--fbz-primary) 100%); }
        .navbar-brand { font-weight: bold; font-size: 1.4rem; }
        .btn-fbz { background-color: var(--fbz-primary); border-color: var(--fbz-primary); color: white; }
        .btn-fbz:hover { background-color: var(--fbz-dark); border-color: var(--fbz-dark); color: white; }
        .card-comic { transition: transform 0.2s, box-shadow 0.2s; }
        .card-comic:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.15); }
        footer { margin-top: auto; background-color: var(--fbz-dark); color: white; padding: 2rem 0; }
        .alert-container { position: fixed; top: 70px; right: 20px; z-index: 1050; max-width: 400px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-book-half me-2"></i>Fantasy B'zaar
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Comics" asp-action="Index">Browse Comics</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Comics" asp-action="AdvancedSearch">Advanced Search</a></li>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Search" asp-action="MyList"><i class="bi bi-bookmark-star"></i> My List</a></li>
                    }
                    @if (User.IsInRole("Staff") || User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-gear"></i> Staff</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">Dashboard</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="TopQueries">Top Queries</a></li>
                                <li><a class="dropdown-item" asp-controller="Admin" asp-action="FlaggedRecords">Flagged Records</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Comics" asp-action="Upload">Upload CSV</a></li>
                            </ul>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-person-circle"></i> @User.Identity.Name</a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><form asp-controller="Account" asp-action="Logout" method="post"><button type="submit" class="dropdown-item">Logout</button></form></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Register</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="alert-container">
        @if (TempData["Success"] != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
        @if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
        @if (TempData["Info"] != null) { <div class="alert alert-info alert-dismissible fade show"><i class="bi bi-info-circle me-2"></i>@TempData["Info"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    </div>

    <main class="container py-4 flex-grow-1">@RenderBody()</main>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5><i class="bi bi-book-half me-2"></i>Fantasy B'zaar</h5>
                    <p class="mb-0">Your premier destination for comic book information.</p>
                    <small class="text-muted">Data: British Library - Comics Unmasked (CC0 1.0)</small>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-0">© @DateTime.Now.Year Fantasy B'zaar</p>
                </div>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
