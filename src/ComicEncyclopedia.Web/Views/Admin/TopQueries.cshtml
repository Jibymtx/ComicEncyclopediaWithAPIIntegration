@model IEnumerable<ComicEncyclopedia.Common.DTOs.SearchQueryDto>
@{
    ViewData["Title"] = "Top Queries";
}

<div class="container mt-4">
    <h2>Top 10 Search Queries</h2>
    <p class="text-muted">Most frequently searched terms</p>
    
    <div class="card">
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Search Query</th>
                        <th>Times Searched</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var rank = 1; }
                    @foreach (var query in Model)
                    {
                        <tr>
                            <td>@rank</td>
                            <td>@query.QueryDescription</td>
                            <td>@query.TimesSearched</td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-action="Dashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
