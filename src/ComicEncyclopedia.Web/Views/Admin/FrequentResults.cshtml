@model IEnumerable<ComicEncyclopedia.Common.DTOs.SearchResultDto>
@{
    ViewData["Title"] = "Frequent Results";
}

<div class="container mt-4">
    <h2>Comics in 100+ Results</h2>
    <p class="text-muted">Comics that have appeared in more than 100 search results</p>
    
    <div class="card">
        <div class="card-body">
            @if (Model.Any())
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Comic Title</th>
                            <th>Times Returned</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var count = 1; }
                        @foreach (var result in Model)
                        {
                            <tr>
                                <td>@count</td>
                                <td>@result.ComicTitle</td>
                                <td>@result.TimesReturned</td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">No comics have appeared in more than 100 search results yet.</p>
            }
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-action="Dashboard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
