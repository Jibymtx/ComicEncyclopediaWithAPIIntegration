@model FlagRecordViewModel
@{ ViewData["Title"] = "Flag Record"; }

<h2><i class="bi bi-flag me-2"></i>Flag Record for Review</h2>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Flagging: @Model.ComicTitle</div>
            <div class="card-body">
                <form asp-action="FlagRecord" method="post">
                    <input type="hidden" asp-for="BLRecordID" />
                    <input type="hidden" asp-for="ComicTitle" />
                    
                    <div class="mb-3">
                        <label asp-for="Reason" class="form-label"></label>
                        <textarea asp-for="Reason" class="form-control" rows="4" placeholder="Describe why this record should be reviewed..."></textarea>
                        <span asp-validation-for="Reason" class="text-danger"></span>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning"><i class="bi bi-flag me-1"></i>Submit Flag</button>
                        <a asp-controller="Comics" asp-action="Details" asp-route-id="@Model.BLRecordID" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
