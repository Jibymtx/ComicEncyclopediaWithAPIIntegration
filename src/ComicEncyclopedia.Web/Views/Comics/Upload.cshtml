@{ ViewData["Title"] = "Upload CSV"; }

<h2><i class="bi bi-upload me-2"></i>Upload Dataset</h2>
<p class="text-muted">Upload the names.csv file from the British Library Comics Unmasked dataset</p>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Upload" method="post" enctype="multipart/form-data" id="uploadForm">
                    <div class="mb-3">
                        <label class="form-label">Select CSV File</label>
                        <input type="file" name="file" id="fileInput" class="form-control" accept=".csv" required>
                        <div class="form-text">Only .csv files are accepted. The file may take a few minutes to process (70,000+ records).</div>
                    </div>
                    
                    <div id="uploadProgress" class="mb-3" style="display: none;">
                        <div class="alert alert-info">
                            <div class="d-flex align-items-center">
                                <div class="spinner-border spinner-border-sm me-3" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <div>
                                    <strong>Processing file...</strong>
                                    <br><small>This may take 1-2 minutes for large files. Please don't close this page.</small>
                                </div>
                            </div>
                        </div>
                        <div class="progress">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%"></div>
                        </div>
                    </div>
                    
                    <button type="submit" id="uploadBtn" class="btn btn-fbz">
                        <i class="bi bi-upload me-2"></i>Upload and Process
                    </button>
                </form>
            </div>
        </div>
        
        <div class="alert alert-warning mt-3">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Important:</strong> Processing 70,000+ records takes time. Please wait for the upload to complete.
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Dataset Information</div>
            <div class="card-body">
                <p><strong>Source:</strong> British Library</p>
                <p><strong>Dataset:</strong> Comics Unmasked</p>
                <p><strong>License:</strong> CC0 1.0 Universal</p>
                <p><strong>Expected File:</strong> names.csv</p>
                <p><strong>Records:</strong> ~70,000+</p>
                <a href="https://www.bl.uk/collection-metadata/downloads" target="_blank" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-box-arrow-up-right me-1"></i>Download from British Library
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('uploadForm').addEventListener('submit', function(e) {
        var fileInput = document.getElementById('fileInput');
        if (fileInput.files.length > 0) {
            document.getElementById('uploadProgress').style.display = 'block';
            document.getElementById('uploadBtn').disabled = true;
            document.getElementById('uploadBtn').innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Uploading...';
        }
    });
</script>
}
