@model ComicDetailsViewModel
@{ ViewData["Title"] = Model.Comic.Title; }

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Comics" asp-action="Index">Comics</a></li>
        <li class="breadcrumb-item active">@Model.Comic.Title</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="mb-0">@Model.Comic.Title</h3>
                @if (Model.Comic.IsFlagged)
                {
                    <span class="badge bg-warning"><i class="bi bi-flag me-1"></i>Flagged</span>
                }
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-4 text-center mb-3 mb-sm-0">
                        @{
                            var placeholder = "https://via.placeholder.com/180x260.png?text=No+Cover+Available";
                            var coverSrc = string.IsNullOrEmpty(Model.CoverUrl) ? placeholder : Model.CoverUrl;
                        }
                        <img id="book-cover-img"
                             src="@coverSrc"
                             alt="Cover for @Model.Comic.Title"
                             class="img-fluid rounded shadow-sm"
                             style="max-height: 260px; object-fit: contain;"
                             onerror="this.onerror=null;this.src='@placeholder';" />
                        <div class="small text-muted mt-2">
                            @if (string.IsNullOrEmpty(Model.CoverUrl))
                            {
                                <span><i class="bi bi-image me-1"></i>No cover available</span>
                            }
                            else
                            {
                                <span><i class="bi bi-book me-1"></i>Cover via Open Library / Google Books</span>
                            }
                        </div>
                    </div>
                    <div class="col-sm-8">
                <dl class="row">
                    <dt class="col-sm-3">BL Record ID</dt>
                    <dd class="col-sm-9"><code>@Model.Comic.BLRecordID</code></dd>

                    <dt class="col-sm-3">Author</dt>
                    <dd class="col-sm-9">@Model.Comic.Author</dd>

                    <dt class="col-sm-3">Publication Date</dt>
                    <dd class="col-sm-9">@(Model.Comic.DateOfPublication ?? "Unknown")</dd>

                    <dt class="col-sm-3">ISBN</dt>
                    <dd class="col-sm-9"><code>@Model.Comic.DisplayISBN</code></dd>

                    <dt class="col-sm-3">Genre</dt>
                    <dd class="col-sm-9">@Model.Comic.Genre</dd>

                    <dt class="col-sm-3">Publisher</dt>
                    <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Comic.Publisher) ? "Unknown" : Model.Comic.Publisher)</dd>

                    <dt class="col-sm-3">Languages</dt>
                    <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Comic.Languages) ? "Unknown" : Model.Comic.Languages)</dd>

                    <dt class="col-sm-3">Edition</dt>
                    <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Comic.Edition) ? "N/A" : Model.Comic.Edition)</dd>

                    <dt class="col-sm-3">Physical Description</dt>
                    <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.Comic.PhysicalDescription) ? "N/A" : Model.Comic.PhysicalDescription)</dd>

                    @if (!string.IsNullOrEmpty(Model.Comic.SeriesTitle))
                    {
                        <dt class="col-sm-3">Series</dt>
                        <dd class="col-sm-9">@Model.Comic.SeriesTitle</dd>
                    }

                    @if (!string.IsNullOrEmpty(Model.Comic.PlaceOfPublication))
                    {
                        <dt class="col-sm-3">Place of Publication</dt>
                        <dd class="col-sm-9">@Model.Comic.PlaceOfPublication</dd>
                    }
                </dl>
                    </div>
                </div>

                @if (Model.Comic.HasVariants)
                {
                    <hr>
                    <h5><i class="bi bi-files me-2"></i>Variant Information</h5>
                    @if (Model.Comic.VariantTitles.Any())
                    {
                        <p><strong>Other Titles:</strong> @string.Join(", ", Model.Comic.VariantTitles)</p>
                    }
                    @if (Model.Comic.VariantISBNs.Any())
                    {
                        <p><strong>Other ISBNs:</strong> @string.Join(", ", Model.Comic.VariantISBNs)</p>
                    }
                    @if (Model.Comic.VariantYears.Any())
                    {
                        <p><strong>Other Years:</strong> @string.Join(", ", Model.Comic.VariantYears)</p>
                    }
                }

                @if (Model.FormattedAllNames.Any())
                {
                    <hr>
                    <h5><i class="bi bi-people me-2"></i>Contributors</h5>
                    <ul>
                        @foreach (var name in Model.FormattedAllNames)
                        {
                            <li>@name</li>
                        }
                    </ul>
                }

                @if (Model.FormattedTopics.Any())
                {
                    <hr>
                    <h5><i class="bi bi-tags me-2"></i>Topics</h5>
                    @foreach (var topic in Model.FormattedTopics)
                    {
                        <span class="badge bg-secondary me-1 mb-1">@topic</span>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header"><i class="bi bi-gear me-2"></i>Actions</div>
            <div class="card-body">
                @if (Model.IsLoggedIn)
                {
                    @if (Model.IsInSearchList)
                    {
                        <form asp-controller="Search" asp-action="Remove" method="post" class="mb-2">
                            <input type="hidden" name="comicId" value="@Model.Comic.BLRecordID" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="btn btn-outline-danger w-100">
                                <i class="bi bi-bookmark-dash me-2"></i>Remove from List
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Search" asp-action="Add" method="post" class="mb-2">
                            <input type="hidden" name="comicId" value="@Model.Comic.BLRecordID" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="btn btn-fbz w-100">
                                <i class="bi bi-bookmark-plus me-2"></i>Add to My List
                            </button>
                        </form>
                    }

                    @if (Model.CanFlag && !Model.Comic.IsFlagged)
                    {
                        <a asp-controller="Admin" asp-action="FlagRecord" asp-route-id="@Model.Comic.BLRecordID" class="btn btn-outline-warning w-100">
                            <i class="bi bi-flag me-2"></i>Flag for Review
                        </a>
                    }
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <a asp-controller="Account" asp-action="Login">Log in</a> to save comics to your list.
                    </div>
                }

                <button type="button"
                        class="btn btn-outline-primary w-100 mt-2"
                        data-bs-toggle="modal"
                        data-bs-target="#emailInfoModal">
                    <i class="bi bi-envelope me-2"></i>Email me more info
                </button>

                <hr>
                <a asp-controller="Comics" asp-action="Index" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Email Info Modal -->
<div class="modal fade" id="emailInfoModal" tabindex="-1" aria-labelledby="emailInfoModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="emailInfoModalLabel">
                    <i class="bi bi-envelope me-2"></i>Email me more info
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">
                    We'll send the details for <strong>@Model.Comic.Title</strong> to your email.
                </p>
                <form id="email-info-form">
                    <div class="mb-3">
                        <label for="email-to" class="form-label">Your email address</label>
                        <input type="email" class="form-control" id="email-to" required placeholder="you@example.com" />
                    </div>
                    <div class="mb-3">
                        <label for="email-name" class="form-label">Your name (optional)</label>
                        <input type="text" class="form-control" id="email-name" placeholder="Name" />
                    </div>
                    <div id="email-result" class="d-none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-fbz" id="email-send-btn">
                    <span class="spinner-border spinner-border-sm d-none" id="email-spinner" role="status" aria-hidden="true"></span>
                    <i class="bi bi-send me-1"></i>Send
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        const comic = {
            title: @Html.Raw(Json.Serialize(Model.Comic.Title)),
            author: @Html.Raw(Json.Serialize(Model.Comic.Author)),
            isbn: @Html.Raw(Json.Serialize(Model.Comic.DisplayISBN)),
            publisher: @Html.Raw(Json.Serialize(Model.Comic.Publisher ?? "")),
            publicationDate: @Html.Raw(Json.Serialize(Model.Comic.DateOfPublication ?? "")),
            genre: @Html.Raw(Json.Serialize(Model.Comic.Genre ?? "")),
            url: window.location.href
        };

        const sendBtn = document.getElementById('email-send-btn');
        const spinner = document.getElementById('email-spinner');
        const resultBox = document.getElementById('email-result');
        const toInput = document.getElementById('email-to');
        const nameInput = document.getElementById('email-name');

        function setResult(type, message) {
            resultBox.className = 'alert alert-' + type;
            resultBox.classList.remove('d-none');
            resultBox.textContent = message;
        }

        function escapeHtml(str) {
            return String(str || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        sendBtn.addEventListener('click', async function () {
            const toEmail = (toInput.value || '').trim();
            if (!toEmail) {
                setResult('warning', 'Please enter your email address.');
                return;
            }

            const toName = (nameInput.value || '').trim() || toEmail;

            const subject = 'Comic info: ' + comic.title;
            const bodyHtml =
                '<h2>' + escapeHtml(comic.title) + '</h2>' +
                '<p>Hi ' + escapeHtml(toName) + ',</p>' +
                '<p>Here are the details you requested from Comic Encyclopedia:</p>' +
                '<ul>' +
                '<li><strong>Title:</strong> ' + escapeHtml(comic.title) + '</li>' +
                '<li><strong>Author:</strong> ' + escapeHtml(comic.author) + '</li>' +
                '<li><strong>ISBN:</strong> ' + escapeHtml(comic.isbn) + '</li>' +
                '<li><strong>Publisher:</strong> ' + escapeHtml(comic.publisher) + '</li>' +
                '<li><strong>Publication Date:</strong> ' + escapeHtml(comic.publicationDate) + '</li>' +
                '<li><strong>Genre:</strong> ' + escapeHtml(comic.genre) + '</li>' +
                '</ul>' +
                '<p><a href="' + escapeHtml(comic.url) + '">View on Comic Encyclopedia</a></p>';

            const bodyText =
                'Title: ' + comic.title + '\n' +
                'Author: ' + comic.author + '\n' +
                'ISBN: ' + comic.isbn + '\n' +
                'Publisher: ' + comic.publisher + '\n' +
                'Publication Date: ' + comic.publicationDate + '\n' +
                'Genre: ' + comic.genre + '\n' +
                'Link: ' + comic.url;

            sendBtn.disabled = true;
            spinner.classList.remove('d-none');
            resultBox.classList.add('d-none');

            try {
                const resp = await fetch('/api/email/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        toEmail: toEmail,
                        toName: toName,
                        subject: subject,
                        bodyHtml: bodyHtml,
                        bodyText: bodyText,
                        provider: 'SendGrid'
                    })
                });

                if (resp.ok) {
                    setResult('success', 'Email sent!');
                    toInput.value = '';
                    nameInput.value = '';
                } else {
                    let msg = 'Could not send email (status ' + resp.status + ').';
                    try {
                        const data = await resp.json();
                        if (data && (data.errorDetails || data.error)) {
                            msg = 'Could not send email: ' + (data.errorDetails || data.error);
                        }
                    } catch (_) { /* ignore parse errors */ }
                    setResult('danger', msg);
                }
            } catch (err) {
                setResult('danger', 'Network error: ' + err.message);
            } finally {
                sendBtn.disabled = false;
                spinner.classList.add('d-none');
            }
        });
    })();
</script>
}
